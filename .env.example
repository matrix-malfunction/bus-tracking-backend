# MongoDB Connection
# Local development
MONGODB_URI=mongodb://localhost:27017/bus_tracker

# Production (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bus_tracker?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=development

# Redis (optional - for caching)
# REDIS_URL=redis://localhost:6379
# REDIS_TTL=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# API Security
# API_KEY_SECRET=your-secret-key-here
# JWT_SECRET=your-jwt-secret

# Logging
LOG_LEVEL=info
# LOG_FORMAT=combined  # combined, dev, common, short, tiny

# Streaming Configuration
STREAM_UPDATE_INTERVAL_MS=1000
MAX_STREAM_CLIENTS=1000

# Performance
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6
DB_POOL_SIZE=10

# Monitoring (optional)
# SENTRY_DSN=https://...@sentry.io/...
# NEW_RELIC_LICENSE_KEY=...
